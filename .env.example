# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=           # e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # public, safe to expose in browser (sb_publishable_...)
SUPABASE_SECRET_KEY=                  # NEVER expose to browser — server + scripts only (sb_secret_...)

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # server-only

# ── Upstash Redis (rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com   # EU region for GDPR

# ── Error monitoring ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # for source map upload at build time
SENTRY_ORG=
SENTRY_PROJECT=

# ── External data sources ────────────────────────────────────────────────────
MANIFESTO_API_KEY=                  # register at manifesto-project.wzb.eu

# ── i18n / Translation (optional for v1) ─────────────────────────────────────
DEEPL_API_KEY=                      # free tier: 500k chars/month

# ── Agora API (set in Vercel env vars — never commit a real value here) ───────
AGORA_INTERNAL_API_KEY=             # agora_... key used by the Löfteskollen demo

# ── Vercel (auto-injected, do not set manually) ───────────────────────────────
# NEXT_PUBLIC_VERCEL_URL
# VERCEL_ENV
