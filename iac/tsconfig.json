{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["bin/**/*", "lib/**/*"],
  "exclude": ["cdk.out", "node_modules", "dist"]
}
